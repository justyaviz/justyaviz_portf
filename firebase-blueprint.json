{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfolio project entry with detailed case study",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "category": { "type": "string", "description": "Display category" },
        "image": { "type": "string", "description": "URL to project cover" },
        "type": { "type": "string", "description": "Slug for filtering (e.g. 'web-site', 'marketing')" },
        "order": { "type": "number", "description": "Display order" },
        "problem": { "type": "string", "description": "Client challenge or problem" },
        "solution": { "type": "string", "description": "Strategy or technical solution" },
        "result": { "type": "string", "description": "Final outcome or metrics" },
        "gallery": { "type": "array", "items": { "type": "string" }, "description": "Additional image URLs" },
        "video": { "type": "string", "description": "YouTube or direct video URL" },
        "link": { "type": "string", "description": "External project link" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "image", "type"]
    },
    "ServicePackage": {
      "title": "Service Package",
      "description": "Defined service offering/pricing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "isPopular": { "type": "boolean" },
        "bentoSize": { "type": "string", "enum": ["small", "medium", "large"] },
        "order": { "type": "number" }
      },
      "required": ["title", "price"]
    },
    "ClientProject": {
      "title": "Client Project Status",
      "description": "Project tracking for clients",
      "type": "object",
      "properties": {
        "clientEmail": { "type": "string" },
        "projectName": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "files": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "url": { "type": "string" } } } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientEmail", "projectName", "status"]
    },
    "SiteContent": {
      "title": "Site Content",
      "description": "Dynamic text content for various sections",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroDesc": { "type": "string" },
        "brandingTitle": { "type": "string" },
        "brandingDesc": { "type": "string" },
        "aboutText": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client feedback",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "content"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "Article for blog/news section",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "image": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content"]
    },
    "AnalyticsEvent": {
      "title": "Analytics Event",
      "description": "Daily aggregated website visits",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "visitors": { "type": "number" },
        "pageviews": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "visitors"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user notifications",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "message", "read"]
    },
    "Experience": {
      "title": "Work Experience",
      "description": "Professional history entry",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "role": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["company", "role"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Academic or professional certification",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "provider": { "type": "string" },
        "image": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "provider"]
    },
    "Message": {
      "title": "Contact Message",
      "description": "Message from contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "content"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "/siteContent/{docId}": {
      "schema": "SiteContent",
      "description": "Singleton or sectional text content"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Collection of client testimonials"
    },
    "/blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of blog/news articles"
    },
    "/services/{serviceId}": {
      "schema": "ServicePackage",
      "description": "Pricing plans and service categories"
    },
    "/clientProjects/{projId}": {
      "schema": "ClientProject",
      "description": "Client-facing project updates"
    },
    "/analytics/{dateId}": {
      "schema": "AnalyticsEvent",
      "description": "Daily analytics statistics"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "Admin notifications"
    },
    "/experience/{expId}": {
      "schema": "Experience",
      "description": "Professional career history"
    },
    "/certificates/{certId}": {
      "schema": "Certificate",
      "description": "Professional and academic certifications"
    },
    "/messages/{msgId}": {
      "schema": "Message",
      "description": "Contact form messages"
    }
  }
}
