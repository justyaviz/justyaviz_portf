rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Very robust check for the specific admin email (case-insensitive)
      return isSignedIn() && 
        request.auth.token.email.matches('(?i)yahyobektohirjonov0@gmail.com');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Site Content collection
    match /siteContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
